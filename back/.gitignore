## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
build/
bld/
[Bb]in/
[Oo]bj/

# Visual Studio cache/options
.vs/

# Rider
.idea/

# Uploads de imagens
wwwroot/uploads/*
!wwwroot/uploads/.gitkeep

# NuGet
*.nupkg
**/[Pp]ackages/*

# Test results
[Tt]est[Rr]esult*/
